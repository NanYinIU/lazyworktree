{
  "name": "lazyworktree",
  "version": "1.0.0",
  "description": "TUI for creating feature worktree groups for Git workspaces",
  "type": "module",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "lazyworktree": "dist/src/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.tsx",
    "build": "tsc -p tsconfig.build.json",
    "prepare": "npm run build",
    "prepublishOnly": "npm test && npm run typecheck",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "commander": "^15.0.0",
    "execa": "^9.6.1",
    "fs-extra": "^11.3.6",
    "ink": "^7.1.0",
    "react": "^19.2.7"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
